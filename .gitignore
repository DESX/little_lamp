# ESP-IDF build dir, toolchain, and cached ESP-IDF clone
out/

# graft download cache
.cache/

# Managed components are pulled at configure time by the IDF Component
# Manager from main/idf_component.yml. Source of truth is the yml and the
# committed dependencies.lock — the downloaded source tree is reproducible.
managed_components/

# sdkconfig.defaults IS the source. sdkconfig and sdkconfig.old are
# regenerated by kconfig from defaults at build time.
sdkconfig
sdkconfig.old

# Unit test binaries (built by tests/unit/Makefile)
tests/unit/test_*
!tests/unit/test_*.c

# Editor / tooling
.vscode/
.idea/
*.swp
*~
.DS_Store
